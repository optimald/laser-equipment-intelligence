{
  "version": 2,
  "buildCommand": "cd laser-procurement-frontend && npm run build",
  "outputDirectory": "laser-procurement-frontend/.next",
  "installCommand": "cd laser-procurement-frontend && npm install",
  "framework": "nextjs",
  "builds": [
    {
      "src": "laser-procurement-frontend/package.json",
      "use": "@vercel/next",
      "config": {
        "zeroConfig": true
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/laser-procurement-frontend/$1"
    }
  ]
}
