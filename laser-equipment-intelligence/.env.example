# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/laser_intelligence
REDIS_URL=redis://localhost:6379/0

# Proxy Services
BRIGHT_DATA_USERNAME=your_bright_data_username
BRIGHT_DATA_PASSWORD=your_bright_data_password
OXYLABS_API_KEY=your_oxylabs_api_key

# CAPTCHA Services
TWOCAPTCHA_API_KEY=your_2captcha_api_key
ANTICAPTCHA_API_KEY=your_anticaptcha_api_key

# Monitoring & Alerts
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
SLACK_WEBHOOK_URL=your_slack_webhook_url

# Scraping Configuration
CONCURRENT_REQUESTS=16
CONCURRENT_REQUESTS_PER_DOMAIN=4
DOWNLOAD_DELAY_MIN=2
DOWNLOAD_DELAY_MAX=10
RANDOMIZE_DOWNLOAD_DELAY=true

# Evasion Settings
STEALTH_MODE=true
FINGERPRINT_EVASION=true
PROXY_ROTATION=true
USER_AGENT_ROTATION=true

# API Keys
GROK_API_KEY=your_grok_api_key
OPENAI_API_KEY=your_openai_api_key

# Environment
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
